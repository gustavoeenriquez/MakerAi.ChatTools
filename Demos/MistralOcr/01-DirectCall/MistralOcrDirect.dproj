<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{D0E1F2A3-B4C5-4D6E-7F8A-9B0C1D2E3F4A}</ProjectGuid>
    <MainSource>MistralOcrDirect.dpr</MainSource>
    <Base>True</Base>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win64</Platform>
    <TargetedPlatforms>1</TargetedPlatforms>
    <AppType>Console</AppType>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base-Win64)'!=''">
    <Base_Win64>true</Base_Win64>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
    <Cfg_1>true</Cfg_1>
    <CfgParent>Base</CfgParent>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win64)'!=''">
    <Cfg_1_Win64>true</Cfg_1_Win64>
    <CfgParent>Cfg_1</CfgParent>
    <Cfg_1>true</Cfg_1>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
    <Cfg_2>true</Cfg_2>
    <CfgParent>Base</CfgParent>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win64)'!=''">
    <Cfg_2_Win64>true</Cfg_2_Win64>
    <CfgParent>Cfg_2</CfgParent>
    <Cfg_2>true</Cfg_2>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Base)'!=''">
    <DCC_DcuOutput>.\$(Platform)\$(Config)</DCC_DcuOutput>
    <DCC_ExeOutput>.\$(Platform)\$(Config)</DCC_ExeOutput>
    <DCC_E>False</DCC_E>
    <DCC_N>False</DCC_N>
    <DCC_S>False</DCC_S>
    <DCC_F>False</DCC_F>
    <DCC_K>False</DCC_K>
    <DCC_UnitSearchPath>$(DCC_UnitSearchPath);..\..\..\..\AiMaker\Source\Core;..\..\..\..\AiMaker\Source\Chat;..\..\..\..\AiMaker\Source\Tools;..\..\..\..\AiMaker\Source\Agents;..\..\..\..\AiMaker\Source\MCPClient;..\..\..\..\AiMaker\Source\MCPServer;..\..\..\..\AiMaker\Source\Utils;..\..\..\..\AiMaker\Source\Embeddings;..\..\..\..\AiMaker\Source\RAG;..\..\..\..\AiMaker\Source\Design;..\..\..\Source\Pdf</DCC_UnitSearchPath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Cfg_1)'!=''">
    <DCC_Optimize>False</DCC_Optimize>
    <DCC_DebugInfoInExe>True</DCC_DebugInfoInExe>
    <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
    <DCC_RemoteDebug>False</DCC_RemoteDebug>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Cfg_2)'!=''">
    <DCC_LocalDebugSymbols>False</DCC_LocalDebugSymbols>
    <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
    <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
    <DCC_Optimize>True</DCC_Optimize>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
  </ItemGroup>
  <ProjectExtensions>
    <Borland.Personality>Delphi.Personality.12</Borland.Personality>
    <Borland.ProjectType>Application</Borland.ProjectType>
    <BorlandProject>
      <Delphi.Personality/>
    </BorlandProject>
    <ProjectFileVersion>12</ProjectFileVersion>
  </ProjectExtensions>
  <Import Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')" Project="$(BDS)\Bin\CodeGear.Delphi.Targets"/>
  <Import Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATADIR)\UserTools.proj')" Project="$(APPDATA)\Embarcadero\$(BDSAPPDATADIR)\UserTools.proj"/>
</Project>
